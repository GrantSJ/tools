# 端口代理
AND,((GEOIP,US),(AND,((PROTOCOL,UDP),(OR,((DEST-PORT,500),(DEST-PORT,4500))))))

# 红包
DOMAIN,config.rcs.mnc280.mcc310.jibecloud.net
DOMAIN,sentitlement2.mobile.att.net
DOMAIN-SUFFIX,mobile.att.net
DOMAIN-KEYWORD,redpocket

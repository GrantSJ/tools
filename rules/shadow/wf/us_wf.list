#!name=Wi-Fi  US
#!desc=美国 SIM 卡 Wi-Fi Call 配置规则
# 本规则适，分流节点须是美国节点。使用本规则后打开飞行模式后再关闭飞行模式进行联网即可正常开启 Wi-Fi call
# 仓库地址：https://github.com/LOWERTOP/Shadowrocket-First

# 端口代理
# AND,((GEOIP,US),(AND,((PROTOCOL,UDP),(OR,((DEST-PORT,500),(DEST-PORT,4500))))))
AND,((AND,((PROTOCOL,UDP),(OR,((DEST-PORT,500),(DEST-PORT,4500))))))

# tell & redpt 全局合规与 SIM 卡鉴权（两大运营商共有） ==============
DOMAIN-SUFFIX,idemia.io

# Tell 
DOMAIN-SUFFIX,msg.t-mobile.com
IP-CIDR,208.54.0.0/16,no-resolve

# Red Pocket (AT&T 体系)  ==============
DOMAIN-SUFFIX,rcs.mnc280.mcc310.jibecloud.net
DOMAIN-SUFFIX,mobile.att.net
DOMAIN-SUFFIX,epdg.epc.att.net
DOMAIN-SUFFIX,epc.att-idns.net
IP-CIDR,107.120.0.0/13,no-resolve
#IP-CIDR,107.120.0.0/16,no-resolve

